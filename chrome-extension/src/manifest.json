{
  "manifest_version": 3,
  "name": "ClassGuard",
  "short_name": "ClassGuard",
  "version": "0.0.1",
  "description": "ClassGuard school internet safety — student device monitoring and policy enforcement.",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "identity",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms",
    "activeTab",
    "scripting",
    "webNavigation",
    "idle",
    "downloads"
  ],

  "storage": {
    "managed_schema": "managed_schema.json"
  },

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "service-worker.bundle.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.bundle.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["youtube-filter.bundle.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ClassGuard",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.bundle.js"],
      "matches":   ["<all_urls>"]
    }
  ],

  "oauth2": {
    "client_id": "__GOOGLE_CLIENT_ID__",
    "scopes": ["openid", "email", "profile"]
  },

  "declarative_net_request": {
    "rule_resources": []
  }
}
