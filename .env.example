# =============================================================================
# ClassGuard Environment Configuration
# Copy to .env and fill in values before starting services.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3001
APP_URL=https://classguard.yourdomain.org
FRONTEND_URL=https://classguard.yourdomain.org

# This server's LAN IP — the admin UI (frontend) and the DNS listener (port
# 53) both bind to this specific address. MUST be a real IP this exact
# machine owns; if you copy this .env to a different server, update both.
# install.sh detects and fills this in automatically.
CLASSGUARD_HOST=YOUR_SERVER_IP
DNS_BIND_IP=YOUR_SERVER_IP

# Only needed if you've set up VRRP HA failover (HA Cluster page) — the
# floating IP that moves between nodes. Set this so the admin UI loads
# correctly when reached via that IP, on whichever node currently holds it.
# Leave blank on a single-node setup or before VRRP is configured.
#VRRP_VIP=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Docker: postgresql://classguard:PASSWORD@postgres:5432/classguard
# Bare metal: postgresql://classguard:PASSWORD@localhost:5432/classguard
DATABASE_URL=postgresql://classguard:CHANGE_ME@postgres:5432/classguard
DB_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Docker: redis://redis:6379
# Bare metal: redis://localhost:6379
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# JWT — generate with: openssl rand -base64 64
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_64
JWT_EXPIRES_IN=8h

# -----------------------------------------------------------------------------
# Google OAuth 2.0 (create at console.cloud.google.com → APIs & Services → Credentials)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://classguard.yourdomain.org/api/v1/auth/google/callback

# -----------------------------------------------------------------------------
# Google Admin SDK (service account with domain-wide delegation)
# See: imageref/ClassGuard-Specification.md §5.3 for setup steps
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/run/secrets/google-service-account.json
GOOGLE_WORKSPACE_DOMAIN=yourdomain.org
GOOGLE_CLASSROOM_ENABLED=false

# -----------------------------------------------------------------------------
# Bootstrap — first login from this email gets superadmin role
# -----------------------------------------------------------------------------
SUPERADMIN_EMAIL=admin@yourdomain.org

# -----------------------------------------------------------------------------
# DNS Engine
# -----------------------------------------------------------------------------
DNS_UPSTREAM_PRIMARY=1.1.1.1
DNS_UPSTREAM_SECONDARY=8.8.8.8
DNS_BLOCK_PAGE_IP=YOUR_SERVER_IP
DNS_LOG_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# DNS Engine HTTP (internal — not exposed externally)
# -----------------------------------------------------------------------------
DNS_HTTP_PORT=3053
BACKEND_URL=http://api:3001
INTERNAL_SECRET=CHANGE_ME_RANDOM_SECRET_FOR_DNS_TO_API_CALLS

# -----------------------------------------------------------------------------
# ISC Kea DHCP
# Docker: http://kea:8000
# Bare metal: http://127.0.0.1:8000
# -----------------------------------------------------------------------------
KEA_CONTROL_AGENT_URL=http://kea:8000
DHCP_NODE_URLS=http://192.168.1.10:8000,http://192.168.1.11:8000

# -----------------------------------------------------------------------------
# Screen monitoring
# -----------------------------------------------------------------------------
SCREENSHOT_STORAGE=none
SCREENSHOT_RETENTION_MINUTES=0

# -----------------------------------------------------------------------------
# Blocklist sync schedule (cron expression)
# -----------------------------------------------------------------------------
BLOCKLIST_SYNC_CRON=0 2 * * *

# -----------------------------------------------------------------------------
# Multi-node / HA
# -----------------------------------------------------------------------------
NODE_ID=node1
NODE_ROLE=primary
RUN_CRON_JOBS=true
