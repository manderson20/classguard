# ============================================================
# Dependencies
# ============================================================
node_modules/
.npm
.yarn/cache
.pnp.*
__pycache__/
*.pyc

# Local-only browser tooling for UI verification — never deployed, not
# part of the app, just a Playwright install used to drive/screenshot
# the live frontend during development.
.devtools/

# ============================================================
# Environment & Secrets — NEVER commit these
# ============================================================
.env
.env.local
.env.*.local
*.env
google-service-account.json
*-service-account.json
*.pem
*.key
*.p12

# ============================================================
# Reference material (screenshots, specs, vendor exports, real infra data)
# — repo is public, never commit any of this
# ============================================================
imageref/
*.pfx

# ============================================================
# Build artifacts
# ============================================================
frontend/dist/
frontend/.vite/
backend/dist/
dns-engine/dist/
*.tsbuildinfo

# ============================================================
# Logs
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# Blocklist compiled data (large, regenerated at runtime)
# ============================================================
blocklists/compiled/
blocklists/cache/

# ============================================================
# Database
# ============================================================
*.sqlite
*.sqlite3
*.db

# ============================================================
# OS & Editor
# ============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# PM2
# ============================================================
.pm2/

# ============================================================
# Docker — dev-only override (node --watch, live source mounts). Never
# tracked: Compose auto-applies this filename with zero opt-in, so if it
# were committed, every fresh clone (including a real production server)
# would silently run in dev mode instead of the built image. Keep your own
# copy locally, untracked.
# ============================================================
docker-compose.override.yml
docker-compose.override.yml.local

# ============================================================
# SSL / Certbot (managed on server, not in repo)
# ============================================================
/infrastructure/nginx/ssl/
/letsencrypt/

# ============================================================
# Test coverage
# ============================================================
coverage/
.nyc_output/
